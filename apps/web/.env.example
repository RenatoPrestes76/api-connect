# apps/web — Seltriva Connect (main app)
# Copy to .env.local for local dev, or set in Vercel Project → Settings → Environment Variables.

# Base URL of the deployed apps/api instance, exposed to the browser.
NEXT_PUBLIC_HUB_API_URL=http://localhost:3001

# Controls the Copilot chat panel's Anthropic integration mode.
# See src/components/copilot/chat-panel.tsx for accepted values.
NEXT_PUBLIC_ANTHROPIC_MODE=demo
