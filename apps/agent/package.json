{
  "name": "@seltriva/agent",
  "version": "0.1.0",
  "description": "Seltriva Connect Agent — Sentinel. Secure edge agent for connecting customer environments to the Seltriva Connect Platform.",
  "private": true,
  "type": "module",
  "bin": {
    "seltriva-agent": "./dist/cli/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@seltriva/core": "workspace:*",
    "@seltriva/types": "workspace:*",
    "@seltriva/runtime": "workspace:*",
    "commander": "^12.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "inquirer": "^10.1.0",
    "node-cron": "^3.0.3",
    "ws": "^8.17.0",
    "axios": "^1.7.0",
    "@supabase/supabase-js": "^2.43.0",
    "@prisma/client": "^5.14.0",
    "better-sqlite3": "^9.6.0",
    "keytar": "^7.9.0",
    "systeminformation": "^5.22.0",
    "semver": "^7.6.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "p-queue": "^8.0.1",
    "p-retry": "^6.2.0",
    "node-forge": "^1.3.1",
    "chokidar": "^3.6.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "@types/better-sqlite3": "^7.6.10",
    "@types/semver": "^7.5.8",
    "@types/node-forge": "^1.3.11",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.14.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
