{
  "name": "@seltriva/api",
  "version": "0.1.0",
  "description": "Seltriva Connect API - Core backend services",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "jose": "^5.2.4",
    "ws": "^8.18.0",
    "@prisma/client": "^5.12.0",
    "@seltriva/activation": "workspace:*",
    "@seltriva/agent-identity": "workspace:*",
    "@seltriva/agent-observability": "workspace:*",
    "@seltriva/agent-provisioning": "workspace:*",
    "@seltriva/config": "workspace:*",
    "@seltriva/core": "workspace:*",
    "@seltriva/database": "workspace:*",
    "@seltriva/database-intelligence": "workspace:*",
    "@seltriva/database-sdk": "workspace:*",
    "@seltriva/logger": "workspace:*",
    "@seltriva/types": "workspace:*",
    "@seltriva/billing": "workspace:*",
    "@seltriva/aegis": "workspace:*",
    "@seltriva/titan": "workspace:*",
    "@seltriva/release": "workspace:*",
    "@seltriva/atlasctl": "workspace:*",
    "@seltriva/connector-registry": "workspace:*",
    "@seltriva/workflow-builder": "workspace:*"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.3",
    "typescript": "^5.4.5",
    "vitest": "^2.1.8"
  }
}
