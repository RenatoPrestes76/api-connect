# apps/cloud — Atlas Cloud Control Plane
# Copy to .env.local for local dev, or set in Vercel Project → Settings → Environment Variables.

# Postgres connection strings for Prisma (prisma/schema.prisma). DIRECT_URL bypasses
# connection pooling and is used for migrations; DATABASE_URL is the pooled runtime
# connection (e.g. Supabase's pgbouncer endpoint). Not required for `prisma generate`
# (which only reads the schema), but required at runtime for any DB-backed route.
DATABASE_URL=postgresql://user:password@localhost:5432/seltriva_cloud
DIRECT_URL=postgresql://user:password@localhost:5432/seltriva_cloud

# Base URL of the deployed apps/api instance, exposed to the browser.
NEXT_PUBLIC_ATLAS_API_URL=http://localhost:3001
