# apps/admin — Seltriva Connect Admin
# Copy to .env.local for local dev, or set in Vercel Project → Settings → Environment Variables.

# Base URL of the deployed apps/api instance. Server-side only (used in Next.js
# API routes under src/app/api/admin/*), so it does NOT need the NEXT_PUBLIC_ prefix.
ADMIN_API_URL=http://localhost:3001

# WebSocket URL of apps/api's fleet/live-updates hub. Exposed to the browser.
NEXT_PUBLIC_ADMIN_API_WS_URL=ws://localhost:3001
