{
  "name": "@seltriva/studio",
  "version": "0.1.0",
  "description": "Seltriva Connect Studio - Development and testing interface",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
