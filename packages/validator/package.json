{
  "name": "@seltriva/validator",
  "version": "0.1.0",
  "description": "Atlas Plugin Validator — manifest, interface, compatibility, security, and performance validation",
  "keywords": [
    "seltriva",
    "atlas",
    "validator",
    "plugin"
  ],
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@seltriva/plugin-sdk": "workspace:*",
    "zod": "^3.23.8",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/semver": "^7.5.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
