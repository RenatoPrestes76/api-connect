{
  "name": "@seltriva/database-sdk",
  "version": "0.2.0",
  "description": "GENESIS — Universal database adapter layer with real driver connections, schema discovery, and SQL dialect support.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:bench": "vitest bench",
    "type-check": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "pg": "^8.12.0",
    "mysql2": "^3.11.3",
    "mssql": "^11.0.1"
  },
  "optionalDependencies": {
    "oracledb": "^6.7.1",
    "node-firebird": "^1.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "@types/mssql": "^9.1.5",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.4.5",
    "vitest": "^2.1.8"
  }
}
