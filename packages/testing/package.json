{
  "name": "@seltriva/testing",
  "version": "0.1.0",
  "description": "Atlas plugin testing framework — test harness, mocks, and assertion helpers",
  "keywords": ["seltriva", "atlas", "testing", "plugin"],
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@seltriva/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "vitest": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
