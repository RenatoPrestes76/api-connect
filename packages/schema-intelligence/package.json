{
  "name": "@seltriva/schema-intelligence",
  "version": "0.1.0",
  "description": "Schema Intelligence Engine (SIE) — universal schema understanding, normalization, comparison and versioning",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./models": {
      "types": "./src/models/index.ts",
      "default": "./src/models/index.ts"
    },
    "./core": {
      "types": "./src/core/index.ts",
      "default": "./src/core/index.ts"
    },
    "./canonical": {
      "types": "./src/canonical/index.ts",
      "default": "./src/canonical/index.ts"
    },
    "./parser": {
      "types": "./src/parser/index.ts",
      "default": "./src/parser/index.ts"
    },
    "./normalizer": {
      "types": "./src/normalizer/index.ts",
      "default": "./src/normalizer/index.ts"
    },
    "./comparator": {
      "types": "./src/comparator/index.ts",
      "default": "./src/comparator/index.ts"
    },
    "./detector": {
      "types": "./src/detector/index.ts",
      "default": "./src/detector/index.ts"
    },
    "./versioning": {
      "types": "./src/versioning/index.ts",
      "default": "./src/versioning/index.ts"
    },
    "./registry": {
      "types": "./src/registry/index.ts",
      "default": "./src/registry/index.ts"
    },
    "./fingerprint": {
      "types": "./src/fingerprint/index.ts",
      "default": "./src/fingerprint/index.ts"
    },
    "./similarity": {
      "types": "./src/similarity/index.ts",
      "default": "./src/similarity/index.ts"
    },
    "./learning": {
      "types": "./src/learning/index.ts",
      "default": "./src/learning/index.ts"
    },
    "./adapters": {
      "types": "./src/adapters/index.ts",
      "default": "./src/adapters/index.ts"
    },
    "./transformers": {
      "types": "./src/transformers/index.ts",
      "default": "./src/transformers/index.ts"
    },
    "./validators": {
      "types": "./src/validators/index.ts",
      "default": "./src/validators/index.ts"
    }
  },
  "dependencies": {
    "@seltriva/core": "workspace:*",
    "@seltriva/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:"
  },
  "scripts": {
    "build": "tsc"
  }
}
