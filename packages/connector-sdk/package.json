{
  "name": "@seltriva/connector-sdk",
  "version": "0.1.0",
  "description": "FUSION — Connector SDK. The extensibility platform that allows developing, installing, updating, and executing any connector without modifying the Runtime.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.4.5",
    "vitest": "^2.1.8"
  }
}
