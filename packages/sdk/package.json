{
  "name": "@seltriva/sdk",
  "version": "0.1.0",
  "description": "Official Seltriva Connect SDK — Atlas Cloud client for external developers",
  "keywords": ["seltriva", "connect", "sdk", "atlas", "enterprise"],
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0",
    "zod": "^3.23.8",
    "jose": "^5.9.6",
    "nanoid": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
