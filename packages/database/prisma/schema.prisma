// @seltriva/database — Prisma Schema
// Atlas Agent Identity & Provisioning
// PostgreSQL
//
// Conventions:
//   - All IDs use CUID2 (@default(cuid()))
//   - Soft deletes via deletedAt DateTime?
//   - All tables have createdAt/updatedAt
//   - Enums are UPPER_SNAKE_CASE
//   - Column names match Prisma field names (camelCase)
//
// After adding or changing models, run:
//   pnpm --filter @seltriva/database db:generate

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum AtlasAgentStatus {
  REGISTERING
  ONLINE
  OFFLINE
  SYNCING
  ERROR
  DISABLED
}

// ─── ATLAS AGENT ─────────────────────────────────────────────────────────────
//
// Represents a Runtime Agent instance installed on a customer's infrastructure.
// Each agent is uniquely identified by its machineId (hardware fingerprint).

model AtlasAgent {
  id                  String           @id @default(cuid())
  companyId           String
  name                String
  machineId           String           @unique
  hostname            String
  connectorType       String
  version             String
  status              AtlasAgentStatus @default(REGISTERING)
  lastHeartbeat       DateTime?
  lastSynchronization DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
}

// ─── AGENT ACCESS TOKEN ──────────────────────────────────────────────────────
//
// Short-lived Bearer credential issued to an AtlasAgent upon provisioning.
// Raw tokens are NEVER stored — only their SHA-256 hash.
// tokenPrefix holds the first 12 chars of the raw token for fast lookup.

model AgentAccessToken {
  id          String    @id @default(cuid())
  agentId     String
  tokenHash   String    @unique
  tokenPrefix String
  expiresAt   DateTime
  revokedAt   DateTime?
  lastUsedAt  DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([agentId])
  @@index([tokenPrefix])
}

// ─── PROVISIONING TOKEN ───────────────────────────────────────────────────────
//
// One-time or long-lived tokens that authorise a Runtime Agent to self-register.
// Raw tokens are NEVER stored — only their SHA-256 hash.
// tokenPrefix holds the first 12 chars of the raw token for fast lookup.

model ProvisioningToken {
  id          String    @id @default(cuid())
  companyId   String
  tokenHash   String    @unique
  tokenPrefix String
  description String
  expiresAt   DateTime
  revokedAt   DateTime?
  lastUsedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([tokenPrefix])
}

// ─── HEARTBEAT HISTORY ────────────────────────────────────────────────────────
//
// Rolling history of heartbeat pings from each Runtime Agent.
// Keep only the last N records per agent (default 500) via application-level cleanup.

model AtlasAgentHeartbeat {
  id          String   @id @default(cuid())
  agentId     String
  receivedAt  DateTime @default(now())
  version     String
  hostname    String
  memoryUsage Int?
  uptime      Int?
  queueSize   Int?
  status      String   // computed HealthStatus (ONLINE/STALE/OFFLINE) at receipt time

  @@index([agentId])
  @@index([agentId, receivedAt])
  @@index([receivedAt])
}

// ─── SYNC HISTORY ─────────────────────────────────────────────────────────────
//
// Record of each synchronisation run per Runtime Agent.
// Keep only the last N records per agent (default 500) via application-level cleanup.

model AtlasAgentSyncHistory {
  id               String   @id @default(cuid())
  agentId          String
  startedAt        DateTime
  finishedAt       DateTime
  durationMs       Int
  recordsSent      Int
  recordsFailed    Int
  bytesTransferred Int
  compressionRatio Float?
  result           String   // SUCCESS | PARTIAL | FAILED

  @@index([agentId])
  @@index([agentId, finishedAt])
  @@index([finishedAt])
}

// ─── ACTIVATION TOKEN ─────────────────────────────────────────────────────────
//
// One-time human-readable token (ATLAS-XXXX-XXXX-XXXX) emitted by the Control
// Plane so a technician can install an Atlas Runtime without editing files.
// Discarded (usedAt set) the moment the installer consumes it.

model ActivationToken {
  id          String    @id
  token       String    @unique
  companyId   String
  environment String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  createdBy   String?

  @@index([token])
  @@index([companyId])
  @@index([expiresAt])
}

// ─── ATLAS CONTROL PLANE — ADMIN IDENTITY (Sprint 46.2) ───────────────────────
//
// Identity, RBAC, session, and audit tables for the Atlas Control Plane admin
// portal (apps/admin) — distinct from AtlasAgent identity above. Declared here
// as the durable schema; the running app currently backs this with an
// in-memory store (see apps/api/src/modules/admin-identity), matching this
// repo's convention of shipping feature-sprint modules DB-schema-first and
// wiring real Prisma persistence in a dedicated migration sprint.

model AtlasAdminRole {
  id          String  @id @default(cuid())
  name        String  @unique
  description String
  isSystem    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       AtlasAdminUser[]
  permissions AtlasRolePermission[]
}

model AtlasPermission {
  id          String @id @default(cuid())
  resource    String
  action      String
  description String

  createdAt DateTime @default(now())

  roles AtlasRolePermission[]

  @@unique([resource, action])
}

model AtlasRolePermission {
  roleId       String
  permissionId String

  role       AtlasAdminRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission AtlasPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model AtlasAdminUser {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  passwordHash       String
  roleId             String
  status             String    @default("active") // active | suspended | disabled
  mfaEnabled         Boolean   @default(false)
  mustChangePassword Boolean   @default(false)
  lastLogin          DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  role     AtlasAdminRole      @relation(fields: [roleId], references: [id])
  sessions AtlasAdminSession[]

  @@index([roleId])
  @@index([email])
}

model AtlasAdminSession {
  id               String    @id @default(cuid())
  adminUserId      String
  refreshTokenHash String    @unique
  ip               String
  userAgent        String
  expiresAt        DateTime
  revokedAt        DateTime?

  createdAt DateTime @default(now())

  adminUser AtlasAdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([refreshTokenHash])
}

model AtlasLoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, ip, createdAt])
}

// Audit trail for admin identity events (LOGIN/LOGOUT/etc.) and, in later
// sprints, business actions (CREATE_COMPANY, UPDATE_RUNTIME, ...). Not one of
// the six tables literally named in the Sprint 46.2 spec, but required by its
// own "toda ação administrativa deve gerar registro" requirement.
model AtlasAdminAuditLog {
  id         String   @id @default(cuid())
  action     String
  actorId    String?
  actorEmail String
  target     String?
  ip         String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([actorId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Merged from apps/cloud/prisma/schema.prisma (Atlas Cloud Control Plane).
// apps/api's routes/services (agents.ts, plugins.ts, agent.service.ts,
// organization.service.ts) depend on these models/enums via the shared
// @prisma/client output, which can only be generated from one schema at a
// time. No model/enum name collisions with the Atlas* models above.
// apps/cloud/prisma/schema.prisma itself is left as-is for now — this is a
// known duplication to reconcile later (single source of truth), not a
// merge back into apps/cloud.
// ─────────────────────────────────────────────────────────────────────────

// ─── ENUMS ────────────────────────────────────────────────────────────────

enum OrganizationTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  DELETED
}

enum WorkspaceStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum EnvironmentKind {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum EnvironmentStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum AgentStatus {
  ONLINE
  OFFLINE
  DEGRADED
  UNRESPONSIVE
  RETIRED
}

enum MemberRole {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  REVOKED
  TRIAL
  PENDING
}

enum PluginStatus {
  PUBLISHED
  DRAFT
  DEPRECATED
  ARCHIVED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

enum JobKind {
  SCHEMA_SYNC
  INCREMENTAL_SYNC
  HEALTH_CHECK
  TELEMETRY_FLUSH
  NOTIFICATION
  AUDIT_EXPORT
  REPORT_GENERATION
  CUSTOM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WEBHOOK
  SLACK
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  INVITE
  ACCEPT_INVITE
  REVOKE_ACCESS
  ACTIVATE
  SUSPEND
  ROTATE_KEY
  INSTALL_PLUGIN
  UNINSTALL_PLUGIN
  REGISTER_AGENT
  DEREGISTER_AGENT
  APPLY_UPDATE
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  PARTIAL
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum FeatureFlagKind {
  BOOLEAN
  PERCENTAGE
  VARIANT
}

// ─── TENANTS (Sprint 46.3) ──────────────────────────────────────────────────
//
// A Tenant is the top-level commercial account — typically 1:1 with an
// Organization, but modeled as 1:many so an enterprise customer can hold
// several Organizations (e.g. separate legal entities/business units) under
// one contract. Added by the Atlas Control Plane; pre-existing standalone
// Organizations keep tenantId nullable.

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CHURNED
}

model Tenant {
  id                  String       @id @default(cuid())
  slug                String       @unique
  name                String
  status              TenantStatus @default(ACTIVE)
  primaryContactEmail String?
  metadata            Json?

  organizations Organization[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([status])
}

// ─── ORGANIZATIONS ────────────────────────────────────────────────────────

model Organization {
  id       String             @id @default(cuid())
  tenantId String?
  slug     String             @unique
  name     String
  tier     OrganizationTier   @default(FREE)
  status   OrganizationStatus @default(ACTIVE)
  logoUrl  String?
  metadata Json?
  settings Json?

  tenant       Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  members      OrganizationMember[]
  workspaces   Workspace[]
  licenses     License[]
  agents       Agent[]
  plugins      OrganizationPlugin[]
  apiKeys      ApiKey[]
  auditEntries AuditEntry[]
  notifications Notification[]
  featureFlags FeatureFlag[]
  jobs         Job[]
  deployments  Deployment[]
  erpIntegration ErpIntegration?
  alerts         RuntimeAlert[]
  deploymentJobs DeploymentJob[]
  metricSnapshots MetricSnapshot[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([status])
  @@index([tier])
  @@index([tenantId])
}

// ─── USERS ────────────────────────────────────────────────────────────────

model User {
  id            String  @id @default(cuid())
  supabaseId    String  @unique
  email         String  @unique
  displayName   String?
  avatarUrl     String?
  emailVerified Boolean @default(false)
  metadata      Json?

  memberships       OrganizationMember[]
  auditEntriesActor AuditEntry[]         @relation("AuditActor")
  notifications     Notification[]       @relation("NotificationRecipient")
  apiKeys           ApiKey[]
  publishedPlugins  Plugin[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@index([supabaseId])
}

model OrganizationMember {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole @default(VIEWER)
  invitedAt      DateTime   @default(now())
  joinedAt       DateTime?
  inviteToken    String?    @unique
  inviteExpiry   DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

// ─── WORKSPACES ───────────────────────────────────────────────────────────

model Workspace {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  status         WorkspaceStatus @default(ACTIVE)
  metadata       Json?

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environments   Environment[]
  configurations Configuration[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, slug])
  @@index([organizationId])
}

// ─── ENVIRONMENTS ─────────────────────────────────────────────────────────

model Environment {
  id          String            @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  kind        EnvironmentKind   @default(DEVELOPMENT)
  status      EnvironmentStatus @default(ACTIVE)
  metadata    Json?

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agents       Agent[]
  featureFlags FeatureFlag[]
  deployments  Deployment[]
  deploymentJobs DeploymentJob[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([kind])
}

// ─── AGENTS ───────────────────────────────────────────────────────────────

model Agent {
  id             String      @id @default(cuid())
  organizationId String
  environmentId  String
  name           String
  version        String
  status         AgentStatus @default(OFFLINE)
  lastSeenAt     DateTime?
  registeredAt   DateTime    @default(now())
  hostname       String?
  ipAddress      String?
  platform       String?
  arch           String?
  nodeVersion    String?
  capabilities   String[]
  metadata       Json?

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environment  Environment       @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  heartbeats   AgentHeartbeat[]
  telemetry    AgentTelemetryLog[]
  commands     AgentCommand[]
  healthSnapshots RuntimeHealthSnapshot[]
  logs         RuntimeLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  retiredAt DateTime?

  @@index([organizationId])
  @@index([environmentId])
  @@index([status])
  @@index([lastSeenAt])
}

model AgentHeartbeat {
  id        String      @id @default(cuid())
  agentId   String
  status    AgentStatus
  cpuPct    Float?
  memPct    Float?
  diskPct   Float?
  latencyMs Int?
  version   String?
  metadata  Json?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  receivedAt DateTime @default(now())

  @@index([agentId])
  @@index([receivedAt])
}

model AgentTelemetryLog {
  id       String  @id @default(cuid())
  agentId  String
  kind     String
  payload  Json
  sizeBytes Int    @default(0)

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  receivedAt DateTime @default(now())

  @@index([agentId])
  @@index([kind])
  @@index([receivedAt])
}

model AgentCommand {
  id          String  @id @default(cuid())
  agentId     String
  commandType String
  payload     Json
  issuedAt    DateTime @default(now())
  expiresAt   DateTime?
  acknowledgedAt DateTime?
  result      Json?
  error       String?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([commandType])
  @@index([issuedAt])
}

// ─── PLUGINS ──────────────────────────────────────────────────────────────

model Plugin {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String
  version     String
  publisherId String
  status      PluginStatus @default(DRAFT)
  category    String
  tags        String[]
  homepage    String?
  repository  String?
  iconUrl     String?
  readme      String?
  manifest    Json
  schema      Json?
  metadata    Json?

  publisher       User                 @relation(fields: [publisherId], references: [id])
  organizations   OrganizationPlugin[]
  versions        PluginVersion[]
  deployments     Deployment[]
  deploymentJobs  DeploymentJob[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([status])
  @@index([category])
}

model PluginVersion {
  id        String @id @default(cuid())
  pluginId  String
  version   String
  changelog String?
  manifest  Json
  published Boolean @default(false)

  plugin        Plugin          @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  deployments   Deployment[]
  deploymentJobs DeploymentJob[]

  publishedAt DateTime?
  createdAt   DateTime @default(now())

  @@unique([pluginId, version])
  @@index([pluginId])
}

// ─── DEPLOYMENTS (Sprint 46.3) ──────────────────────────────────────────────
//
// A rollout of a specific PluginVersion (connector) to an Organization's
// Environment. Runtime (Agent) version updates are tracked directly on the
// Agent record rather than through Deployment.

enum DeploymentStatus {
  PENDING
  IN_PROGRESS
  SUCCEEDED
  FAILED
  ROLLED_BACK
}

model Deployment {
  id              String           @id @default(cuid())
  organizationId  String
  environmentId   String
  pluginId        String
  pluginVersionId String
  status          DeploymentStatus @default(PENDING)
  triggeredBy     String?
  error           String?
  metadata        Json?

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environment   Environment   @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  plugin        Plugin        @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  pluginVersion PluginVersion @relation(fields: [pluginVersionId], references: [id], onDelete: Cascade)

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([organizationId])
  @@index([environmentId])
  @@index([pluginId])
  @@index([status])
}

model OrganizationPlugin {
  id             String @id @default(cuid())
  organizationId String
  pluginId       String
  version        String
  config         Json?
  enabled        Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plugin       Plugin       @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([organizationId, pluginId])
  @@index([organizationId])
  @@index([pluginId])
}

// ─── LICENSES ─────────────────────────────────────────────────────────────

model License {
  id             String        @id @default(cuid())
  organizationId String
  key            String        @unique
  tier           OrganizationTier
  status         LicenseStatus @default(ACTIVE)
  maxAgents      Int           @default(5)
  maxWorkspaces  Int           @default(3)
  maxUsers       Int           @default(10)
  features       String[]
  activatedAt    DateTime?
  expiresAt      DateTime?
  metadata       Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([expiresAt])
}

// ─── FEATURE FLAGS ────────────────────────────────────────────────────────

model FeatureFlag {
  id             String          @id @default(cuid())
  organizationId String?
  environmentId  String?
  key            String
  kind           FeatureFlagKind @default(BOOLEAN)
  enabled        Boolean         @default(false)
  rolloutPercent Int?
  variants       Json?
  description    String?
  expiresAt      DateTime?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environment  Environment?  @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([organizationId, environmentId, key])
  @@index([key])
  @@index([organizationId])
  @@index([environmentId])
}

// ─── CONFIGURATION ────────────────────────────────────────────────────────

model Configuration {
  id          String  @id @default(cuid())
  workspaceId String
  key         String
  value       String
  encrypted   Boolean @default(false)
  description String?
  metadata    Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@index([key])
}

// ─── JOBS ─────────────────────────────────────────────────────────────────

model Job {
  id             String    @id @default(cuid())
  organizationId String?
  kind           JobKind
  name           String
  status         JobStatus @default(PENDING)
  payload        Json?
  result         Json?
  error          String?
  attempt        Int       @default(0)
  maxAttempts    Int       @default(3)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  expiresAt      DateTime?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([kind])
  @@index([status])
  @@index([scheduledAt])
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────

model Notification {
  id             String              @id @default(cuid())
  organizationId String?
  recipientId    String?
  channel        NotificationChannel
  status         NotificationStatus  @default(PENDING)
  title          String
  body           String
  data           Json?
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  failureReason  String?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipient    User?         @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([recipientId])
  @@index([channel])
  @@index([status])
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────

model AuditEntry {
  id             String       @id @default(cuid())
  organizationId String?
  actorId        String?
  action         AuditAction
  outcome        AuditOutcome @default(SUCCESS)
  resource       String
  resourceId     String?
  ipAddress      String?
  userAgent      String?
  before         Json?
  after          Json?
  metadata       Json?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  occurredAt DateTime @default(now())

  @@index([organizationId])
  @@index([actorId])
  @@index([action])
  @@index([resource])
  @@index([occurredAt])
}

// ─── API KEYS ─────────────────────────────────────────────────────────────

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  name           String
  keyHash        String       @unique
  keyPrefix      String
  status         ApiKeyStatus @default(ACTIVE)
  scopes         String[]
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  metadata       Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  revokedAt DateTime?

  @@index([organizationId])
  @@index([keyPrefix])
  @@index([status])
}

// ─── METRICS SNAPSHOTS ────────────────────────────────────────────────────

model MetricSnapshot {
  id             String @id @default(cuid())
  organizationId String
  agentId        String?
  kind           String
  value          Float
  unit           String?
  labels         Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  recordedAt DateTime @default(now())

  @@index([organizationId])
  @@index([agentId])
  @@index([kind])
  @@index([recordedAt])
}

// ─── FLEET OPERATIONS (Sprint 46.4) ─────────────────────────────────────────
//
// RuntimeMetric and RuntimeCommand are intentionally NOT new models here —
// AgentHeartbeat (cpuPct/memPct/diskPct/latencyMs/status/receivedAt) and
// AgentCommand (commandType/payload/result/error/issuedAt) already cover them
// exactly. AuditTimeline is also not a new model — it's a presentation over
// the existing admin audit log (see modules/admin-identity). Only genuinely
// new concepts get new tables below.

enum HealthCheckStatus {
  PASS
  WARN
  FAIL
}

model RuntimeHealthSnapshot {
  id       String @id @default(cuid())
  agentId  String
  status   HealthCheckStatus
  checks   Json // [{ name, status, message }]
  metadata Json?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  recordedAt DateTime @default(now())

  @@index([agentId])
  @@index([recordedAt])
}

model RuntimeLog {
  id       String  @id @default(cuid())
  agentId  String
  level    String // INFO | WARN | ERROR
  message  String
  source   String?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([level])
  @@index([createdAt])
}

enum AlertType {
  RUNTIME_OFFLINE
  HIGH_CPU
  HIGH_MEMORY
  SYNC_FAILURE
  CONNECTOR_STOPPED
  DEPLOY_FAILED
  TOKEN_EXPIRING
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

model RuntimeAlert {
  id             String        @id @default(cuid())
  organizationId String
  agentId        String?
  pluginId       String?
  deploymentId   String?
  type           AlertType
  severity       AlertSeverity
  status         AlertStatus   @default(ACTIVE)
  message        String
  metadata       Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt    DateTime  @default(now())
  acknowledgedAt DateTime?
  resolvedAt   DateTime?

  @@index([organizationId])
  @@index([agentId])
  @@index([type])
  @@index([severity])
  @@index([status])
}

enum NotificationChannelKind {
  EMAIL
  WEBSOCKET
  SLACK
  TEAMS
  WEBHOOK
}

enum FleetNotificationStatus {
  PENDING
  SENT
  FAILED
}

model FleetNotification {
  id            String                   @id @default(cuid())
  channel       NotificationChannelKind
  target        String
  subject       String?
  body          String
  relatedAlertId String?
  status        FleetNotificationStatus  @default(PENDING)
  error         String?

  createdAt DateTime  @default(now())
  sentAt    DateTime?

  @@index([channel])
  @@index([status])
  @@index([relatedAlertId])
}

enum DeploymentMode {
  MANUAL
  AUTOMATIC
  SCHEDULED
}

enum DeploymentJobStatus {
  PENDING_APPROVAL
  SCHEDULED
  APPROVED
  IN_PROGRESS
  SUCCEEDED
  FAILED
  REJECTED
  ROLLED_BACK
}

model DeploymentJob {
  id              String               @id @default(cuid())
  organizationId  String
  environmentId   String
  pluginId        String
  pluginVersionId String
  mode            DeploymentMode
  status          DeploymentJobStatus  @default(PENDING_APPROVAL)
  scheduledAt     DateTime?
  requestedBy     String?
  approvedBy      String?
  error           String?

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environment   Environment   @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  plugin        Plugin        @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  pluginVersion PluginVersion @relation(fields: [pluginVersionId], references: [id], onDelete: Cascade)
  tasks         DeploymentTask[]

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  @@index([organizationId])
  @@index([environmentId])
  @@index([status])
  @@index([scheduledAt])
}

model DeploymentTask {
  id     String @id @default(cuid())
  jobId  String
  name   String
  status String // PENDING | RUNNING | SUCCEEDED | FAILED
  order  Int

  job DeploymentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  startedAt   DateTime?
  completedAt DateTime?

  @@index([jobId])
}

// ─── ERP INTEGRATION MODE ─────────────────────────────────────────────────
// Foundation-only: identifies which ERP integration mode a company uses
// (OFF = replica/offline database, ON = direct ERP connection). No pricing,
// ERP write path, or automated sync/rebate logic lives on this model.

enum ErpIntegrationType {
  OFF
  ON
}

enum ErpIntegrationStatus {
  ACTIVE
  INACTIVE
}

model ErpIntegration {
  id             String @id @default(cuid())
  organizationId String @unique

  integrationType ErpIntegrationType   @default(OFF)
  status          ErpIntegrationStatus @default(ACTIVE)

  erpName String?
  host     String?
  database String?
  schema   String?

  lastConnectionAt DateTime?
  lastSyncAt       DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([integrationType])
  @@index([status])
}
