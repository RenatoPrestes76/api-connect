{
  "name": "@seltriva/cli",
  "version": "0.1.0",
  "description": "Atlas CLI — developer toolchain for building and publishing Seltriva plugins",
  "keywords": ["seltriva", "atlas", "cli", "plugin", "connector"],
  "license": "MIT",
  "private": false,
  "type": "module",
  "bin": {
    "atlas": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@seltriva/plugin-sdk": "workspace:*",
    "@seltriva/sdk": "workspace:*",
    "@seltriva/validator": "workspace:*",
    "@seltriva/generator": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.1",
    "inquirer": "^12.3.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8",
    "semver": "^7.6.3",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/semver": "^7.5.8",
    "@types/tar": "^6.1.13",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
