{
  "name": "@seltriva/agent-provisioning",
  "version": "0.1.0",
  "description": "HERMES-II — Atlas Agent Persistence & Provisioning. Connects the agent-identity domain to Prisma persistence and implements the provisioning token flow.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@seltriva/agent-identity": "workspace:*",
    "@seltriva/database": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.4.5",
    "vitest": "^2.1.8"
  }
}
