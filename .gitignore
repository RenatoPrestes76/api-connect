# Global gitignore for Seltriva Connect monorepo

# Dependencies
node_modules/
pnpm-lock.yaml
package-lock.json
yarn.lock

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo
.turbo/

# Environment
.env
.env.local
.env.*.local
.env.production.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Testing
coverage/
.nyc_output/
jest.log

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Database
*.db
*.db-journal
*.sqlite
*.sqlite3
prisma/dev.db

# Cache
.cache/
.eslintcache
.stylelintcache

# OS
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride

# Docker
.dockerignore
docker-compose.override.yml

# Temp files
tmp/
temp/
*.tmp

# Local runtime data (e.g. disaster-recovery backup snapshots)
.data/
