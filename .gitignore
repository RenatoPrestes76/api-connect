# Global gitignore for Seltriva Connect monorepo

# Dependencies
node_modules/
# pnpm-lock.yaml is intentionally tracked (single source of truth for a pnpm
# workspace) — untracking it means fresh clones (CI, Vercel, Docker) never
# get a lockfile at all, breaking `pnpm install --frozen-lockfile` everywhere.
package-lock.json
yarn.lock

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo
.turbo/

# Compiled JS must never live under a package's src/ (TypeScript source
# only) — this has leaked in from tsc rootDir/outDir misconfiguration more
# than once. Note: .d.ts is NOT included here — some packages have
# legitimate hand-written ambient declaration files (env.d.ts, globals.d.ts)
# committed under src/.
**/src/**/*.js
**/src/**/*.js.map
**/src/**/*.d.ts.map

# Environment
.env
.env.local
.env.*.local
.env.production.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Testing
coverage/
.nyc_output/
jest.log

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Database
*.db
*.db-journal
*.sqlite
*.sqlite3
prisma/dev.db

# Cache
.cache/
.eslintcache
.stylelintcache

# OS
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride

# Docker
.dockerignore
docker-compose.override.yml

# Temp files
tmp/
temp/
*.tmp

# Local runtime data (e.g. disaster-recovery backup snapshots)
.data/
