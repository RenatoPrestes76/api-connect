{
  "name": "seltriva-connect",
  "version": "0.1.0",
  "description": "Enterprise API platform built for scale, security, and reliability",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build --filter='!./apps/docs'",
    "build:all": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:cloud": "turbo run dev --filter='./apps/cloud'",
    "dev:api": "turbo run dev --filter='./apps/api'",
    "dev:studio": "turbo run dev --filter='./apps/studio'",
    "dev:agent": "turbo run dev --filter='./apps/agent'",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint --env-mode=loose -- --fix",
    "format": "prettier --write '**/*.{ts,tsx,json,md,yml,yaml}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,md,yml,yaml}'",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "clean": "turbo clean && pnpm -r clean",
    "db:push": "turbo run db:push --filter='./packages/database'",
    "db:generate": "turbo run db:generate --filter='./packages/database'",
    "validate": "pnpm lint && pnpm type-check && pnpm format:check",
    "prepare": "husky",
    "env:validate": "node scripts/validate-env.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.3.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-turbo": "^2.0.4",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "prettier": "^3.2.5",
    "turbo": "^2.0.11",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.4.5"
    }
  }
}
